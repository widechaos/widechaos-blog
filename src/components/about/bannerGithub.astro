---
const githubUrl = "https://github.com/widechaos";
const imageUrl = "/github.png";
---

<section class="mt-16 flex justify-center px-4">
	<div
		class="mx-auto max-h-80 w-full max-w-[1120px] overflow-hidden rounded-2xl bg-linear-to-r from-[#211355] to-[#12186e] text-white shadow-lg drop-shadow-[4px_4px_0_#7836cf]"
	>
		<div class="flex h-full flex-col items-center md:flex-row-reverse md:items-start">
			<!-- Logo GitHub -->
			<div class="flex h-full w-full shrink-0 items-center justify-center md:w-auto md:justify-end">
				<a href={githubUrl} target="_blank" rel="noopener noreferrer">
					<img
						src={imageUrl}
						alt="GitHub 标识"
						class="h-auto w-72 cursor-pointer object-contain transition hover:scale-105 md:w-[470px]"
						width="940"
						height="500"
						loading="lazy"
						decoding="async"
					/>
				</a>
			</div>

			<!-- Texto y botón -->
			<div class="flex-1 p-4 text-center md:p-8 md:text-left">
				<h3 class="text-5xl font-bold md:text-4xl">访问我的 GitHub</h3>
				<p class="mt-2 text-sm md:text-xl">欢迎查看项目与代码实践。</p>
				<a
					href={githubUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="mt-4 inline-block rounded-full bg-white px-6 py-3 font-semibold text-black transition hover:bg-gray-200"
				>
					打开 GitHub
				</a>
			</div>
		</div>
	</div>
</section>
