---
import SocialIcons from "../socialIcons/socialIcons.jsx";
import { SITE_CONFIG } from "../../../config/site";

const links = SITE_CONFIG.navItems.filter((item) => item.href !== "/");
---

<footer class="bg-gray-950 text-white">
  <div
    class="container mx-auto flex flex-col items-center justify-between px-6 py-12 lg:flex-row lg:px-20"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <h3
        class="text-[#69c7c7] text-4xl font-bold drop-shadow-[1.5px_1.5px_0_#7836cf]"
      >
        {SITE_CONFIG.author}
      </h3>
    </a>

    <!-- Navigation Links -->
    <nav class="mb-4 lg:mb-0">
      <ul
        class="flex flex-col items-center space-y-2 text-gray-400 lg:flex-row lg:items-start lg:space-y-0 lg:space-x-6"
      >
        {
          links.map((link) => (
            <li>
              <a href={link.href} class="hover:text-[#552496] font-semibold">
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/feed.xml" class="hover:text-[#552496] font-semibold">RSS</a>
        </li>
        <li>
          <a href="/sitemap.xml" class="hover:text-[#552496] font-semibold">
            站点地图
          </a>
        </li>
      </ul>
    </nav>

    <!-- Social Media Links -->
    <div class="flex space-x-4 ">
      <SocialIcons client:visible />
    </div>
  </div>

  <!-- Copyright -->
  <div
    class="w-full border-t border-gray-600 py-10 text-center text-sm text-gray-500"
  >
    <a
      class="font-semibold text-gray-400 transition-colors hover:text-[#69c7c7]"
      href={`mailto:${SITE_CONFIG.email}`}
    >
      {SITE_CONFIG.email}
    </a>
  </div>
</footer>
