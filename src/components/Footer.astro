---
import { SITE_CONFIG } from '../config/site';
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800 py-8">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <!-- 版权信息 -->
      <div class="text-gray-600 dark:text-gray-400 text-sm">
        <p>© {new Date().getFullYear()} {SITE_CONFIG.author}</p>
        <p class="mt-1">基于 Astro 构建 | 
          <a href="/rss.xml" class="hover:text-blue-600 dark:hover:text-blue-400 ml-2">RSS</a>
          <a href="/sitemap.xml" class="hover:text-blue-600 dark:hover:text-blue-400 ml-2">站点地图</a>
        </p>
      </div>
      
      <div class="text-gray-600 dark:text-gray-400 text-sm">
        <p>{SITE_CONFIG.location}</p>
      </div>
      
      <div class="text-gray-600 dark:text-gray-400 text-sm">
        <a class="hover:text-blue-600 dark:hover:text-blue-400" href={`mailto:${SITE_CONFIG.email}`}>
          {SITE_CONFIG.email}
        </a>
      </div>
    </div>
  </div>
</footer>
