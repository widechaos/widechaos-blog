---
import { SITE_CONFIG } from '../config/site';

const postFiles = import.meta.glob('../content/blog/*.{md,mdx}', { eager: true });
const postsArray = Object.values(postFiles);
const totalPosts = postsArray.filter((post) => !post.frontmatter?.draft).length;
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800 py-8">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <div class="text-gray-600 dark:text-gray-400 text-sm">
        <p>© {new Date().getFullYear()} {SITE_CONFIG.author} - 十方空烬</p>
        <p class="mt-1">基于 Astro 构建 | 
          <a href="/feed.xml" class="hover:text-blue-600 dark:hover:text-blue-400 ml-2">RSS</a>
          <a href="/sitemap.xml" class="hover:text-blue-600 dark:hover:text-blue-400 ml-2">站点地图</a>
        </p>
      </div>
      
      <div class="text-gray-600 dark:text-gray-400 text-sm">
        <p>
          <span id="site-runtime"></span> 天 | 总文章:{" "}
          <span id="total-posts">{totalPosts}</span>
        </p>
      </div>

      <div class="flex items-center space-x-4">
        {Object.entries(SITE_CONFIG.social).map(
          ([platform, url]) =>
            url && (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                aria-label={platform}
              >
                {platform === "github" && "GitHub"}
                {platform === "twitter" && "Twitter"}
                {platform === "linkedin" && "LinkedIn"}
                {platform === "bilibili" && "B站"}
                {platform === "zhihu" && "知乎"}
              </a>
            )
        )}
      </div>
    </div>
  </div>
  
  <script is:inline>
    const startDate = new Date("2024-01-01");
    const today = new Date();
    const diffTime = Math.abs(today - startDate);
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    const runtimeEl = document.getElementById("site-runtime");
    if (runtimeEl) runtimeEl.textContent = String(diffDays);
  </script>
</footer>
