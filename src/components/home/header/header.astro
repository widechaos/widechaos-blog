---
import SocialIcons from "../../commons/socialIcons/socialIcons.jsx";
import TypeEfect from "../header/typeEfect.jsx";
import { getCollection } from "astro:content";
import { PROJECTS } from "../../../config/site";

const posts = await getCollection("blog");
const tags = posts
  .filter((p) => !p.data.draft)
  .flatMap((p) => p.data.tags ?? [])
  .map((t) => String(t).trim())
  .filter(Boolean);

const tagCounts = tags.reduce<Record<string, number>>((acc, tag) => {
  acc[tag] = (acc[tag] ?? 0) + 1;
  return acc;
}, {});

const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"))
  .slice(0, 6)
  .map(([tag]) => tag);

const projectTech = PROJECTS.flatMap((p) => p.tech ?? [])
  .map((t) => String(t).trim())
  .filter(Boolean);

const keywordSet = new Set([
  ...topTags,
  ...projectTech,
  "Agent",
  "RAG",
  "LLM",
  "MLOps",
  "Function-calling",
  "UX/UI",
]);

const keywords = Array.from(keywordSet).slice(0, 10);
---

<header class="relative h-screen bg-gray-950 overflow-hidden">
  <div class="absolute inset-0 grid grid-cols-2">
    <div
      class="animate-gradientMove h-80 bg-linear-to-br from-[#982cf0] to-[#581f86] opacity-30 blur-[120px]"
    >
    </div>
    <div
      class="animate-gradientMove2 h-80 bg-linear-to-br from-[#277752] to-[#02ffee] opacity-30 blur-[120px]"
    >
    </div>
  </div>

  <main
    class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
  >
    <h1 class="text-4xl md:text-7xl font-bold text-white text-shadow mt-10">
      构建、思考、破界
    </h1>

    <TypeEfect client:visible strings={keywords} />

    <p
      class="text-xs md:text-xl text-white max-w-sm md:max-w-xl font-semibold mt-3"
    >
      专注 AI 应用工程化与云原生技术，聚焦 RAG、Agent 与 DevOps。
      这里记录工程实践、技术洞察与产品化思考。
    </p>
    <SocialIcons client:visible />
    <a
      href="/projects"
      class="px-6 py-3 bg-primary hover:bg-secondary mt-3 text-white font-semibold rounded-3xl transition-all duration-150
         drop-shadow-[2px_2px_0_#0debd8] active:translate-0.5 active:drop-shadow-none"
    >
      查看项目
    </a>
  </main>
</header>
