---
import "../styles/global.css";
import Navbar from "../components/commons/navbar/navbar.astro";
import Footer from "../components/commons/footer/footer.astro";
import BaseHead from "../components/BaseHead.astro";
import { SITE_CONFIG } from "../config/site";

const {
  title,
  description,
  image,
  noindex = false,
} = Astro.props;
---

<html lang="zh-CN" class="dark">
  <head>
    <BaseHead
      title={title}
      description={description ?? SITE_CONFIG.description}
      image={image}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen bg-[#0b0616] text-gray-100 antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
