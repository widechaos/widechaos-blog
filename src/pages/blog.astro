---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="博客" description="技术探索、工程实践与生活思考的记录">
  <div class="mx-auto max-w-4xl px-4 py-14">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white">博客文章</h1>
      <p class="mt-3 text-white/70">这里记录我的思考、学习与工程实践</p>
    </div>

    <div class="space-y-6">
      {publishedPosts.map((post) => {
        const firstTag = post.data.tags?.[0] ?? "未分类";
        const readTime =
          typeof post.data.readTime === "number"
            ? `${post.data.readTime} 分钟`
            : null;

        return (
          <article class="rounded-2xl border border-white/10 bg-gray-950/30 p-6 shadow-lg shadow-black/20 transition-colors hover:border-white/20">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="min-w-0">
                <h2 class="text-2xl font-bold text-white">
                  <a
                    href={`/blog/${post.slug}`}
                    class="transition-colors hover:text-[#69c7c7]"
                  >
                    {post.data.title}
                  </a>
                </h2>
                {post.data.description && (
                  <p class="mt-2 line-clamp-2 text-white/70">
                    {post.data.description}
                  </p>
                )}
              </div>

              <a
                href={`/tags/${encodeURIComponent(firstTag.toLowerCase())}`}
                class="inline-flex shrink-0 items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-semibold text-white/80 transition-colors hover:border-white/20 hover:text-white"
              >
                #{firstTag}
              </a>
            </div>

            <div class="mt-5 flex flex-col gap-3 text-sm text-white/70 md:flex-row md:items-center md:justify-between">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("zh-CN")}
                </time>
                {post.data.author && (
                  <span class="ab-a-only">作者：{post.data.author}</span>
                )}
                {readTime && <span class="ab-a-only">阅读：{readTime}</span>}
                <span class="ab-b-only">打开阅读 →</span>
              </div>
              <a
                href={`/blog/${post.slug}`}
                class="font-semibold text-[#69c7c7] transition-colors hover:text-white"
              >
                阅读全文 →
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <div class="mt-10 rounded-xl border border-white/10 bg-white/5 p-5 text-white/80">
      共 <span class="font-bold text-white">{publishedPosts.length}</span> 篇文章
    </div>
  </div>
</Layout>
