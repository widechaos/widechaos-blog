---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const pubDate = post.data.pubDate;
const tags = post.data.tags ?? [];
const readTime =
  typeof post.data.readTime === "number" ? `${post.data.readTime} 分钟` : null;
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-14">
    <header class="border-b border-white/10 pb-8">
      <h1 class="text-4xl font-extrabold text-white">{post.data.title}</h1>

      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-white/70">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString("zh-CN")}
        </time>
        {post.data.author && <span>作者：{post.data.author}</span>}
        {readTime && <span>阅读：{readTime}</span>}
      </div>

      {tags.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag.toLowerCase())}`}
              class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white/80 transition-colors hover:border-white/20 hover:text-white"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div
      class="mt-10 leading-relaxed text-white/90 [&_a]:text-[#69c7c7] [&_a]:underline-offset-4 hover:[&_a]:text-white [&_a]:transition-colors [&_code]:rounded [&_code]:bg-white/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-white [&_h3]:mt-8 [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-white [&_p]:mt-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:mt-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_blockquote]:mt-6 [&_blockquote]:border-l-4 [&_blockquote]:border-white/15 [&_blockquote]:pl-4 [&_blockquote]:text-white/80"
    >
      <Content />
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <a
        href="/blog"
        class="font-semibold text-white/70 transition-colors hover:text-[#69c7c7]"
      >
        ← 返回博客列表
      </a>
    </div>
  </article>
</Layout>
