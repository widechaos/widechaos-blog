---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{post.data.title}</h1>
      <div class="mt-3 text-sm text-gray-600 dark:text-gray-400 flex flex-wrap gap-x-4 gap-y-1">
        <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</time>
        <span>作者：{post.data.author}</span>
        {post.data.readTime && <span>阅读：{post.data.readTime}</span>}
      </div>
      {post.data.tags?.length ? (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}`}
              class="text-xs px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-200"
            >
              #{tag}
            </a>
          ))}
        </div>
      ) : null}
    </header>

    <div class="prose dark:prose-invert max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-800">
      <a href="/blog" class="text-sm text-purple-600 dark:text-purple-400 hover:underline">← 返回博客列表</a>
    </div>
  </article>
</Layout>
