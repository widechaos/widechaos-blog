---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const postsByYear = publishedPosts.reduce<Record<string, typeof publishedPosts>>(
  (acc, post) => {
    const year = String(post.data.pubDate.getFullYear());
    const yearPosts = acc[year] ?? [];
    yearPosts.push(post);
    acc[year] = yearPosts;
    return acc;
  },
  {}
);
---

<Layout title="归档" description="所有博客文章按年份归档">
  <div class="mx-auto max-w-3xl px-4 py-14">
    <h1 class="text-4xl font-bold text-white">文章归档</h1>

    <div class="mt-10 space-y-12">
      {Object.keys(postsByYear)
        .sort()
        .reverse()
        .map((year) => (
          <section>
            <h2 class="text-2xl font-bold text-white">{year}</h2>
            <div class="mt-6 space-y-4">
              {postsByYear[year].map((post) => {
                const formattedDate = post.data.pubDate.toLocaleDateString(
                  "zh-CN",
                  {
                    month: "short",
                    day: "numeric",
                  }
                );

                return (
                  <article class="group border-l-2 border-white/10 pl-6 py-2 transition-colors hover:border-[#69c7c7]">
                    <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                      <div class="min-w-0">
                        <h3 class="text-lg font-semibold text-white transition-colors group-hover:text-[#69c7c7]">
                          <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                        </h3>
                        {post.data.description && (
                          <p class="line-clamp-2 text-sm text-white/70">
                            {post.data.description}
                          </p>
                        )}
                      </div>

                      <div class="flex items-center gap-3">
                        <div class="flex gap-2">
                          {(post.data.tags ?? []).slice(0, 2).map((tag) => (
                            <a
                              href={`/tags/${encodeURIComponent(
                                tag.toLowerCase()
                              )}`}
                              class="rounded bg-white/5 px-2 py-1 text-xs text-white/80 transition-colors hover:bg-white/10 hover:text-white"
                            >
                              {tag}
                            </a>
                          ))}
                        </div>
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class="whitespace-nowrap text-sm text-white/60"
                        >
                          {formattedDate}
                        </time>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}
    </div>

    <div class="mt-12 rounded-xl border border-white/10 bg-white/5 p-6 text-white/80">
      共 <span class="font-bold text-white">{publishedPosts.length}</span> 篇文章
    </div>
  </div>
</Layout>
