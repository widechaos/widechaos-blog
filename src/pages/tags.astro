---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { TAG_CONFIG } from "../config/site";

const posts = await getCollection("blog");
const publishedPosts = posts.filter((post) => !post.data.draft);

const tagCounts = publishedPosts.reduce<Record<string, number>>((acc, post) => {
  (post.data.tags ?? []).forEach((tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
  });
  return acc;
}, {});

const allTags = Object.keys(tagCounts).sort((a, b) => a.localeCompare(b, "zh"));

const TAG_VARIANTS: Record<string, string> = {
  技术: "tech",
  编程: "code",
  生活: "life",
  思考: "think",
  读书: "read",
  量化: "quant",
  AI: "ai",
  默认: "default",
};

function getTagVariant(tag: string) {
  if (Object.prototype.hasOwnProperty.call(TAG_CONFIG.colors, tag)) {
    return TAG_VARIANTS[tag] ?? "default";
  }
  return "default";
}
---

<Layout title="标签" description="按标签浏览博客文章">
  <div class="mx-auto max-w-4xl px-4 py-14">
    <h1 class="text-4xl font-bold text-white">标签</h1>

    <div class="mt-10">
      <h2 class="text-2xl font-bold text-white">所有标签</h2>
      <div class="mt-6 flex flex-wrap gap-3">
        {allTags.map((tag) => {
          const count = tagCounts[tag] ?? 0;
          const variant = getTagVariant(tag);

          return (
            <a
              href={`/tags/${encodeURIComponent(tag.toLowerCase())}`}
              class:list={[
                "tag-chip group relative inline-flex items-center gap-2 rounded-lg border px-4 py-2 font-semibold transition-transform hover:scale-105",
                `tag-chip--${variant}`,
              ]}
            >
              <span>#{tag}</span>
              <span class="rounded bg-white/10 px-1.5 py-0.5 text-xs text-white/90">
                {count}
              </span>
            </a>
          );
        })}
      </div>
    </div>

    <div class="mt-14">
      <h2 class="text-2xl font-bold text-white">按标签浏览</h2>
      <div class="mt-8 space-y-10">
        {allTags.map((tag) => {
          const variant = getTagVariant(tag);
          const taggedPosts = publishedPosts
            .filter((post) => (post.data.tags ?? []).includes(tag))
            .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

          return (
            <section>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class:list={["tag-heading text-xl font-bold", `tag-heading--${variant}`]}>
                  #{tag}
                </h3>
                <span class="text-sm text-white/70">
                  {taggedPosts.length} 篇文章
                </span>
              </div>

              <div class="mt-4 grid gap-4 md:grid-cols-2">
                {taggedPosts.slice(0, 4).map((post) => {
                  const formattedDate = post.data.pubDate.toLocaleDateString(
                    "zh-CN",
                    {
                      month: "short",
                      day: "numeric",
                    }
                  );

                  return (
                    <a href={`/blog/${post.slug}`} class="group block">
                      <div class="rounded-lg border border-white/10 bg-gray-950/20 p-4 transition-colors hover:border-white/20">
                        <h4 class="font-semibold text-white transition-colors group-hover:text-[#69c7c7]">
                          {post.data.title}
                        </h4>
                        <time
                          datetime={post.data.pubDate.toISOString()}
                          class="mt-2 block text-sm text-white/60"
                        >
                          {formattedDate}
                        </time>
                      </div>
                    </a>
                  );
                })}
              </div>

              {taggedPosts.length > 4 && (
                <div class="mt-4 text-center">
                  <a
                    href={`/tags/${encodeURIComponent(tag.toLowerCase())}`}
                    class="inline-block text-sm font-semibold text-white/70 transition-colors hover:text-[#69c7c7]"
                  >
                    查看全部 {taggedPosts.length} 篇文章 →
                  </a>
                </div>
              )}
            </section>
          );
        })}
      </div>
    </div>
  </div>
</Layout>
