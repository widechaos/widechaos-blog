---
import Layout from "../layouts/Layout.astro";
import { SITE_CONFIG } from "../config/site";
import CopyMail from "../components/links/copyMail.jsx";
---

<Layout>
  <section class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold mb-6">联系我</h1>
    <p class="text-gray-700 dark:text-gray-300">
      如果你想交流大模型应用工程化、RAG/Agent落地或云原生存储相关问题，欢迎通过以下方式联系。
    </p>

    <div class="mt-8 grid gap-4">
      <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-800">
        <h2 class="text-lg font-semibold mb-2">邮箱</h2>
        <a class="text-purple-600 dark:text-purple-400 hover:underline" href={`mailto:${SITE_CONFIG.email}`}>
          {SITE_CONFIG.email}
        </a>
        <div class="mt-4">
          <CopyMail client:visible />
        </div>
      </div>

      <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-800">
        <h2 class="text-lg font-semibold mb-2">电话</h2>
        <a class="text-purple-600 dark:text-purple-400 hover:underline" href={`tel:${SITE_CONFIG.phone}`}>
          {SITE_CONFIG.phone}
        </a>
      </div>

      <div class="p-6 rounded-xl border border-gray-200 dark:border-gray-800">
        <h2 class="text-lg font-semibold mb-2">地区</h2>
        <p class="text-gray-700 dark:text-gray-300">{SITE_CONFIG.location}</p>
      </div>
    </div>
  </section>
</Layout>
